generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  RU
  UA
  EN
  PL
}

enum UserRole {
  USER
  SUPPORT
  MODERATOR
  ADMIN
  OWNER
}

enum ServerStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  LIQPAY
  FONDY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  steamId64   String?    @unique
  discordId   String?    @unique
  username    String?
  role        UserRole   @default(USER)
  locale      Locale     @default(RU)
  isBanned    Boolean    @default(false)
  orders      Order[]
  payments    Payment[]
  adminLogs   AdminLog[] @relation("AdminActor")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Server {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  map         String
  mode        String
  ip          String
  port        Int?
  playerLimit Int          @default(100)
  onlineCount Int          @default(0)
  status      ServerStatus @default(ONLINE)
  description String
  rules       String[]
  products    Product[]
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  serverId    String
  server      Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  slug        String
  name        String
  description String
  imageUrl    String?
  priceEur    Decimal       @db.Decimal(10, 2)
  priceUah    Decimal       @db.Decimal(10, 2)
  pricePln    Decimal       @db.Decimal(10, 2)
  compareAtEur Decimal?      @db.Decimal(10, 2)
  discountPercent Int?
  saleEndsAt  DateTime?
  currency    String        @default("EUR")
  status      ProductStatus @default(ACTIVE)
  isCosmetic  Boolean       @default(true)
  noAdvantage Boolean       @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([serverId, slug])
}

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  serverId        String?
  server          Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  promoCodeId     String?
  promoCode       PromoCode?   @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  status          OrderStatus  @default(PENDING)
  currency        String       @default("EUR")
  subtotalAmount  Decimal      @db.Decimal(10, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal      @db.Decimal(10, 2)
  steamId64       String?
  discordId       String?
  items           OrderItem[]
  payments        Payment[]
  deliveredAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider          PaymentProvider
  providerPaymentId String?
  status            PaymentStatus   @default(PENDING)
  currency          String          @default("EUR")
  amount            Decimal         @db.Decimal(10, 2)
  rawPayload        Json?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  usageLimit      Int
  usedCount       Int      @default(0)
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model News {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  body          String
  imageUrl      String?
  publishOnHome Boolean   @default(false)
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AdminActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}
